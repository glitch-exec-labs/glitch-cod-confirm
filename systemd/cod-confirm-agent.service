[Unit]
Description=Glitch COD Confirm — LiveKit voice agent worker (Priya / Sarvam Bulbul v3)
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=support
WorkingDirectory=/home/support/glitch-cod-confirm
EnvironmentFile=/home/support/glitch-cod-confirm/.env
Environment=PATH=/home/support/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
# `start` is production mode (info log, no hot reload). Use `dev` locally for debug.
ExecStart=/usr/bin/node src/livekit-agent.js start
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cod-confirm-agent

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/support/glitch-cod-confirm

[Install]
WantedBy=multi-user.target
